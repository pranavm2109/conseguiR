# Raw input data
data/raw/**
!data/raw/
!data/raw/.gitkeep

# Generated working outputs only; never ship package assets from here.
# Rebuildable backend graphs, vignette outputs, test artifacts, and other
# local products belong in `data/processed/` and stay ignored.
data/processed/**
!data/processed/
!data/processed/.gitkeep

# Package-shipped backend resources live only under `inst/extdata/backend/`.
# These are the backend seeds/resources that installed users receive.
!inst/
!inst/extdata/
!inst/extdata/backend/
!inst/extdata/backend/NCBI38.gene.loc
!inst/extdata/backend/gene_gene_graph_nodes_compact.tsv.xz
!inst/extdata/backend/gene_gene_graph_edges_compact.tsv.xz
!inst/extdata/backend/gene_reg_graph_no_scores_nodes_compact.tsv.xz
!inst/extdata/backend/gene_reg_graph_no_scores_edges_compact.tsv.xz
!inst/extdata/backend/reg_target_labels.tsv.gz

# macOS metadata and Python/R build junk
.DS_Store
._*
__pycache__/
*.pyc
.Rhistory
Rplots.pdf
*.log.suppl

# Local external tools used during development but not shipped with the package
tools/magma_v*/
tools/magma_v*.*/

# Local BiocCheck output
conseguiR.BiocCheck/

# Generated vignette build artifacts
vignettes/*.log
vignettes/*_cache/
