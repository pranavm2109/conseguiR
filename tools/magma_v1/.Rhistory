str(genes_with_sym)
head(genes_with_sym, 20)
df <- genes_with_sym %>%
mutate(
neglogP = -log10(ifelse(is.na(P) | P <= 0, 1e-300, P))
)
top_hits <- df %>%
arrange(P) %>%
slice_head(n = 15)
ggplot(df, aes(x = ZSTAT, y = neglogP)) +
geom_point(alpha = 0.5, size = 1.2, color = "grey40") +
geom_point(data = top_hits, aes(x = ZSTAT, y = neglogP),
color = "red", size = 1.8) +
ggrepel::geom_text_repel(
data = top_hits,
aes(label = SYMBOL),
size = 3,
max.overlaps = 20,
box.padding = 0.3,
point.padding = 0.2
) +
labs(
x = "Z-statistic",
y = expression(-log[10](P)),
title = "MAGMA Gene-based Volcano Plot"
) +
theme_minimal(base_size = 12)
