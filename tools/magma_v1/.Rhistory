score    = df_lab$score
)
# Make the main panel a bit taller (optional but nice)
kp <- karyoploteR::plotKaryotype(genome = genome, cex = 0.5, plot.type = 2)
# panel 1 range helper (optional)
r0 <- 0.05; r1 <- 0.45
karyoploteR::kpAddBaseNumbers(kp, tick.dist = 50e6, cex = 0.5, r0 = r0, r1 = r1)
karyoploteR::kpAxis(kp, ymin = 0, ymax = score_cap, numticks = 6, cex = 0.5, r0 = r0, r1 = r1)
# BARS — tell it the y-scale
karyoploteR::kpBars(
kp,
data = gr_all,
y0 = 0,
y1 = gr_all$score,
ymin = 0, ymax = score_cap,
border = NA,
data.panel = 1,
r0 = r0, r1 = r1
)
# CONNECTORS — same y-scale
karyoploteR::kpSegments(
kp,
data = gr_lab,
x0 = df_lab$mid, x1 = df_lab$mid,
y0 = df_lab$score, y1 = df_lab$lab_y,
ymin = 0, ymax = score_cap,
col = "#555555", lwd = 1, data.panel = 1,
r0 = r0, r1 = r1
)
# LABELS — same y-scale
karyoploteR::kpText(
kp,
data   = gr_lab,
x      = df_lab$mid,
y      = df_lab$lab_y,
ymin = 0, ymax = score_cap,
labels = df_lab$SYMBOL,
cex    = 0.5, col = "#222222",
data.panel = 1,
pos    = 3,
r0 = r0, r1 = r1
)
