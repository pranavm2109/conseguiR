pos    = 3
)
genome <- "hg19"
score_cap <- 30
genes_with_sym <- genes_with_sym %>%
mutate(
CHR   = as.integer(CHR),
START = as.integer(START),
STOP  = as.integer(STOP),
P     = suppressWarnings(as.numeric(P))
)
df <- genes_with_sym %>%
mutate(
chr_str = case_when(
CHR == 23 ~ "chrX",
CHR == 24 ~ "chrY",
TRUE      ~ paste0("chr", CHR)
),
P = ifelse(is.na(P) | P <= 0, 1e-300, P),
score = -log10(P),
score = pmin(score, score_cap),
SYMBOL = ifelse(is.na(SYMBOL) | SYMBOL == "", paste0("ENTREZ_", GENE), SYMBOL),
mid = as.integer((START + STOP) / 2)
) %>%
filter(is.finite(score), !is.na(START), !is.na(STOP), START <= STOP, !is.na(mid))
df_top_global <- df %>% arrange(P) %>% slice_head(n = 10)
df_top_perchr <- df %>% group_by(chr_str) %>% arrange(P) %>% slice_head(n = 2) %>% ungroup()
df_lab <- bind_rows(df_top_global, df_top_perchr) %>%
distinct(SYMBOL, .keep_all = TRUE) %>%
arrange(chr_str, P) %>%
group_by(chr_str) %>%
mutate(
y_off  = (row_number() - 1) %% 3,
base_y = pmin(score, score_cap - 1),
lab_y  = pmin(score_cap, base_y + 1 + 0.8 * y_off)
) %>%
ungroup()
if (any(duplicated(df_lab[, c("chr_str", "mid")]))) {
df_lab <- df_lab %>%
group_by(chr_str, mid) %>%
mutate(mid = mid + (row_number() - 1L) * 5000L) %>%
ungroup()
}
gr_all <- GenomicRanges::GRanges(
seqnames = df$chr_str,
ranges   = IRanges::IRanges(df$mid, width = 1),
score    = df$score
)
gr_lab <- GenomicRanges::GRanges(
seqnames = df_lab$chr_str,
ranges   = IRanges::IRanges(df_lab$mid, width = 1),
score    = df_lab$score
)
kp <- karyoploteR::plotKaryotype(
genome = genome,
cex = 0.5
)
karyoploteR::kpAddBaseNumbers(kp, tick.dist = 50e6, cex = 0.5)
karyoploteR::kpAxis(kp, ymin = 0, ymax = score_cap, numticks = 6, cex = 0.5)
karyoploteR::kpBars(
kp,
data = gr_all,
y0   = 0,
y1   = gr_all$score,
border = NA,
data.panel = 1
)
karyoploteR::kpSegments(
kp,
data = gr_lab,
x0 = df_lab$mid, x1 = df_lab$mid,
y0 = df_lab$score, y1 = df_lab$lab_y,
col = "#555555", lwd = 1, data.panel = 1
)
karyoploteR::kpText(
kp,
data   = gr_lab,
x      = df_lab$mid,
y      = df_lab$lab_y,
labels = df_lab$SYMBOL,
cex    = 0.5, col = "#222222",
data.panel = 1,
pos    = 3
)
