w_min <- 1e5
# for all genes: use actual gene length with a lower bound
all_widths <- pmax(df$STOP - df$START + 1L, w_min)
gr_all <- GenomicRanges::GRanges(
seqnames = df$chr_str,
ranges   = IRanges::IRanges(start = df$mid - all_widths %/% 2L,
width = all_widths),
score    = df$score
)
# for labeled genes: ensure they’re also wide enough (same rule)
lab_widths <- pmax(df_lab$STOP - df_lab$START + 1L, w_min)
gr_lab <- GenomicRanges::GRanges(
seqnames = df_lab$chr_str,
ranges   = IRanges::IRanges(start = df_lab$mid - lab_widths %/% 2L,
width = lab_widths),
score    = df_lab$score
)
# ---- Draw (keep your y-scale & panels as you set earlier) ----
karyoploteR::kpBars(
kp,
data = gr_all,
y0 = 0, y1 = gr_all$score,
ymin = 0, ymax = score_cap,
border = NA,
data.panel = 1,
r0 = r0, r1 = r1
)
# Optionally make labeled ones pop by overplotting:
karyoploteR::kpBars(
kp,
data = gr_lab,
y0 = 0, y1 = gr_lab$score,
ymin = 0, ymax = score_cap,
border = NA,
data.panel = 1,
r0 = r0, r1 = r1
)
